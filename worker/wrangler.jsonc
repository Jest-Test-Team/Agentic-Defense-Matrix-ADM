{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "adm-api-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2024-11-01",
  "observability": { "enabled": true },
  // Targets for the proxy. Cloudflare Workers CANNOT fetch a raw IP (returns
  // error 1003), so use a hostname — nip.io maps <ip>.nip.io -> <ip> with no DNS
  // setup. Update the embedded IP on each replace_instance deploy (or use a
  // reserved IP / real domain).
  "vars": {
    "ADM_ANALYSIS_URL": "http://161.33.209.244.nip.io:8090",
    "ADM_GATEWAY_URL": "http://161.33.209.244.nip.io:8080"
  }
}
